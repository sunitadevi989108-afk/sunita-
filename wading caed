const AUDIO_SRC = "https://upload.wikimedia.org/wikipedia/commons/0/09/Shahnai_Bismillah_Khan.ogg";

let globalAudio: HTMLAudioElement | null = null;

function getGlobalAudio() {
  if (!globalAudio) {
    globalAudio = new Audio(AUDIO_SRC);
    globalAudio.loop = true;
  }
  return globalAudio;
}

function MusicPlayer() {
  const [playing, setPlaying] = useState(false);
  const [blocked, setBlocked] = useState(false);

  useEffect(() => {
    const audio = getGlobalAudio();
    const tryPlay = () => {
      audio.play().then(() => {
        setPlaying(true);
        setBlocked(false);
      }).catch(() => setBlocked(true));
    };
    tryPlay();

    const onInteract = () => {
      audio.play().then(() => {
        setPlaying(true);
        setBlocked(false);
        document.removeEventListener("click", onInteract);
        document.removeEventListener("touchstart", onInteract);
      }).catch(() => {});
    };
    document.addEventListener("click", onInteract);
    document.addEventListener("touchstart", onInteract);

    const sync = () => setPlaying(!audio.paused);
    audio.addEventListener("play", sync);
    audio.addEventListener("pause", sync);
    return () => {
      audio.removeEventListener("play", sync);
      audio.removeEventListener("pause", sync);
      document.removeEventListener("click", onInteract);
      document.removeEventListener("touchstart", onInteract);
    };
  }, []);

  const toggle = () => {
    const audio = getGlobalAudio();
    if (audio.paused) {
      audio.play().then(() => setPlaying(true)).catch(() => {});
    } else {
      audio.pause();
      setPlaying(false);
    }
  };

  return (
    <div className="flex flex-col items-center gap-1">
      <motion.div
        className="flex items-center gap-3 px-5 py-3 rounded-full cursor-pointer select-none shadow-md"
        style={{
          background: "linear-gradient(135deg, #fffbe788, #f5c84222)",
          border: "1.5px solid #d4af37aa",
        }}
        whileTap={{ scale: 0.95 }}
        onClick={toggle}
      >
        <motion.span
          className="text-2xl"
          animate={playing ? { scale: [1, 1.15, 1] } : {}}
          transition={{ duration: 1, repeat: Infinity }}
        >
          {playing ? "⏸" : "▶"}
        </motion.span>
        <div className="flex flex-col">
          <span className="text-amber-800 text-xs font-bold tracking-wide">
            🎵 Shehnai — Bismillah Khan
          </span>
          <span className="text-amber-600 text-[10px]">Wedding Blessing Music</span>
        </div>
        {playing && (
          <div className="flex gap-0.5 items-end h-5">
            {[1, 2, 3, 4].map((b) => (
              <motion.div
                key={b}
                className="w-1 rounded-full bg-amber-500"
                animate={{ height: ["3px", "16px", "6px", "16px", "3px"] }}
                transition={{ duration: 0.8, delay: b * 0.12, repeat: Infinity }}
              />
            ))}
          </div>
        )}
      </motion.div>
      {blocked && !playing && (
        <p className="text-[10px] text-amber-600 animate-pulse">
          Tap anywhere to play music 🎶
        </p>
      )}
    </div>
  );
}

const CURTAIN_FLOWERS = Array.from({ length: 28 }, (_, i) => {
  const angle = (i / 28) * 360;
  const rad = (angle * Math.PI) / 180;
  const dist = 180 + (i % 4) * 60;
  const emojis = ["🌸", "🌺", "🌹", "🌼", "🪷", "💮"];
  return {
    id: i,
    tx: Math.cos(rad) * dist,
    ty: Math.sin(rad) * dist,
    rotate: angle * 2,
    emoji: emojis[i % emojis.length],
    size: 20 + (i % 4) * 8,
    delay: (i % 6) * 0.035,
    duration: 0.55 + (i % 3) * 0.08,
  };
});

const SWEEP_FLOWERS = Array.from({ length: 20 }, (_, i) => ({
  id: i,
  top: (i / 20) * 110 - 5,
  delay: i * 0.04,
  emoji: ["🌸", "🌺", "🌹", "🌼", "🪷"][i % 5],
  size: 18 + (i % 3) * 10,
}));

// FIX #3: FlowerCurtain was defined but never used — now exported and ready to use.
// Usage: place <FlowerCurtain id={curtainKey} /> inside WeddingCard when navigating pages.
function FlowerCurtain({ id }: { id: number }) {
  if (id === 0) return null;
  return (
    <motion.div
      key={id}
      className="fixed inset-0 z-[90] pointer-events-none flex items-center justify-center overflow-hidden"
      initial={{ opacity: 1 }}
      animate={{ opacity: [1, 1, 0] }}
      transition={{ duration: 1.0, times: [0, 0.65, 1] }}
    >
      {/* Radial burst from center */}
      {CURTAIN_FLOWERS.map((f) => (
        <motion.div
          key={f.id}
          className="absolute select-none"
          style={{ fontSize: f.size, lineHeight: 1 }}
          initial={{ x: 0, y: 0, opacity: 0, rotate: 0, scale: 0 }}
          animate={{
            x: f.tx,
            y: f.ty,
            opacity: [0, 1, 1, 0],
            rotate: f.rotate,
            scale: [0, 1.3, 1, 0.5],
          }}
          transition={{
            duration: f.duration,
            delay: f.delay,
            ease: "easeOut",
          }}
        >
          {f.emoji}
        </motion.div>
      ))}

      {/* FIX #1: Was using Unicode minus U+2212 "−" instead of ASCII hyphen-minus "-"
          Both the string "−110vw" and the numeric −30 were using the wrong character,
          causing a runtime error / incorrect CSS value in Framer Motion. */}
      {SWEEP_FLOWERS.map((f) => (
        <motion.div
          key={`sweep-${f.id}`}
          className="absolute select-none"
          style={{
            top: `${f.top}%`,
            fontSize: f.size,
            lineHeight: 1,
          }}
          initial={{ x: "-110vw", opacity: 0, rotate: -30 }}
          animate={{
            x: ["-110vw", "0vw", "110vw"],
            opacity: [0, 1, 1, 0],
            rotate: [-30, 0, 30],
          }}
          transition={{
            duration: 0.75,
            delay: 0.15 + f.delay,
            ease: "easeInOut",
          }}
        >
          {f.emoji}
        </motion.div>
      ))}
    </motion.div>
  );
}

