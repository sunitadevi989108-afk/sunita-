export default function WeddingCard() {
  const [page, setPage] = useState(0);
  const [showSplash, setShowSplash] = useState(true);
  const autoTimer = useRef<ReturnType<typeof setTimeout> | null>(null);

  const goToPage = (next: number) => {
    setPage(next);
    if (autoTimer.current) clearTimeout(autoTimer.current);
  };

  // FIX #4: Auto-advance was using (p + 1) % 5 which wraps Page5 back to Page1.
  // Now it stops advancing once the last page is reached.
  useEffect(() => {
    if (showSplash) return;
    const LAST_PAGE = 4;
    if (page >= LAST_PAGE) return; // Do not auto-advance past the last page
    autoTimer.current = setTimeout(() => {
      setPage((p) => p + 1);
    }, 10000);
    return () => {
      if (autoTimer.current) clearTimeout(autoTimer.current);
    };
  }, [page, showSplash]);

  useEffect(() => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  }, [page]);

  const pages = [
    <Page1 key={0} onNext={() => goToPage(1)} />,
    <Page2 key={1} onNext={() => goToPage(2)} />,
    <Page3 key={2} onNext={() => goToPage(3)} />,
    <Page4 key={3} onNext={() => goToPage(4)} />,
    <Page5 key={4} />,
  ];

  return (
    <div
      className="min-h-screen relative overflow-x-hidden"
      style={{ background: "linear-gradient(160deg, #fffef5 0%, #fdf3d0 60%, #fef9e7 100%)" }}
    >
      <AnimatePresence>
        {showSplash && <SplashScreen onDone={() => setShowSplash(false)} />}
      </AnimatePresence>

      <Petals />

      <div className="relative z-10">
        <AnimatePresence mode="wait">
          <motion.div
            key={page}
            variants={pageVariants}
            initial="initial"
            animate="animate"
            exit="exit"
          >
            {pages[page]}
          </motion.div>
        </AnimatePresence>
      </div>

      {page > 0 && (
        <button
          onClick={() => goToPage(Math.max(0, page - 1))}
          className="fixed top-4 left-4 z-50 w-9 h-9 rounded-full flex items-center justify-center text-amber-700 text-sm"
          style={{ background: "#fff8", border: "1px solid #d4af3766" }}
        >
          ←
        </button>
      )}

      <div className="fixed bottom-4 left-0 right-0 flex flex-col items-center gap-1.5 z-50">
        {!showSplash && (
          <motion.div
            className="overflow-hidden rounded-full"
            style={{ width: 80, height: 2, background: "#d4af3733" }}
          >
            <motion.div
              key={page}
              className="h-full rounded-full"
              style={{ background: "linear-gradient(to right, #d4af37, #f5c842)" }}
              initial={{ width: "0%" }}
              animate={{ width: "100%" }}
              transition={{ duration: 10, ease: "linear" }}
            />
          </motion.div>
        )}
        <div className="flex gap-2">
          {Array.from({ length: 5 }).map((_, i) => (
            <button
              key={i}
              onClick={() => goToPage(i)}
              className="rounded-full transition-all duration-300"
              style={{
                width: page === i ? 20 : 8,
                height: 8,
                background: page === i ? "#d4af37" : "#d4af3766",
              }}
            />
          ))}
        </div>
      </div>
    </div>
  );
}
